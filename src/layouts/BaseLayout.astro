---
import '../styles/global.css';
import SEOHead from '../components/SEOHead.astro';
import StructuredData from '../components/StructuredData.astro';

interface Props {
  title: string;
  description?: string;
  image?: string;
  noindex?: boolean;
}

const {
  title,
  description = 'Site Factory generated website',
  image,
  noindex = false,
} = Astro.props;

// Site-wide structured data (customize in intake/INTAKE.md)
const organizationData = {
  name: "[Business Name]",
  url: Astro.site?.href,
  logo: new URL('/images/logo.png', Astro.site).href,
  // Add more fields from INTAKE.md: address, phone, email, social profiles
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />

    <!-- Preconnect to external origins (fonts, analytics) -->
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />

    <!-- Google Fonts with font-display: swap for performance -->
    <!-- Update this URL based on intake/branding/fonts.md -->
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap"
      rel="stylesheet"
    />

    <!-- Complete Favicon Set -->
    <link rel="icon" href="/favicon.ico" sizes="32x32" />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/manifest.webmanifest" />

    <!-- Theme color for browser UI -->
    <meta name="theme-color" content="#ffffff" />

    <!-- SEO Meta Tags (includes Open Graph and Twitter Cards) -->
    <SEOHead
      title={title}
      description={description}
      image={image}
      noindex={noindex}
    />

    <!-- Organization Structured Data (site-wide) -->
    <StructuredData type="Organization" data={organizationData} />
  </head>
  <body class="font-body text-neutral-900 bg-neutral-50 antialiased">
    <slot />
  </body>
</html>
