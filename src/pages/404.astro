---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Page Not Found">
  <main class="min-h-screen flex items-center justify-center bg-neutral-50">
    <div class="text-center px-4">
      <h1 class="text-8xl font-display font-bold text-primary mb-4">404</h1>
      <h2 class="text-2xl font-display text-neutral-700 mb-4">Page Not Found</h2>
      <p class="text-neutral-600 mb-8 max-w-md mx-auto">
        The page you're looking for doesn't exist or has been moved.
      </p>
      <a
        href="/"
        class="inline-block px-6 py-3 bg-primary text-white font-medium rounded-lg hover:bg-primary/90 transition-colors"
      >
        Return Home
      </a>
    </div>
  </main>
</BaseLayout>
