---
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
---

<BaseLayout
  title="Schedule Your Mouth Destiny — CHOMPERZ™"
  description="Book your appointment with Dr. Crystal Molarstone. Fill out the form and claim your dental destiny in Los Angeles."
>
  <Header />

  <main id="main-content">

  <!-- ═══ PAGE HERO ═══ -->
  <section class="page-hero" aria-labelledby="sched-heading">
    <div class="page-hero-glow" aria-hidden="true"></div>
    <p class="page-hero-eyebrow" aria-hidden="true">✦ THE TIME HAS COME ✦</p>
    <h1 id="sched-heading">
      <span class="h1-solid">SCHEDULE</span>
      <span class="h1-outline">YOUR MOUTH</span>
      <span class="h1-solid">DESTINY</span>
    </h1>
    <p class="page-hero-sub">You've waited long enough. Your teeth have waited longer. <strong>Let's do this.</strong></p>
  </section>

  <!-- ═══ URGENCY BAR ═══ -->
  <div class="urgency-bar" role="status" aria-live="polite" aria-atomic="false">
    <span aria-hidden="true">⚡</span>
    <strong>LIMITED APPOINTMENT SLOTS REMAIN THIS WEEK</strong> —
    Dr. Molarstone's calendar is filling up fast — Next available slot closes in:
    <span id="countdown" aria-label="countdown timer">09:47</span>
    <span aria-hidden="true">⚡</span>
  </div>

  <div class="divider" aria-hidden="true"></div>

  <!-- ═══ FORM + INTRO ═══ -->
  <div class="form-outer">

    <div class="form-intro">
      <div class="form-intro-text">
        <p>We're thrilled — genuinely <em>thrilled</em> — that you're here. Taking this step means your teeth mean something to you. And they mean something to us, too. Possibly more than they mean to you, which is fine. We accept that.</p>
        <p>Fill out the form and we'll match you with a <strong>personalized mouth destiny appointment</strong> within one (1) business day, or possibly two, or whenever Dr. Molarstone gets the notification.</p>
        <p>If this is a <em>dental emergency</em>, please add that in the notes and text <strong>(555) TOOTH-ME</strong> immediately. And breathe. Your tooth has survived this long. It can hold on a few more minutes.</p>
      </div>
      <ul class="trust-list" aria-label="What to expect">
        <li>All mouths welcomed without judgment</li>
        <li>Complimentary tooth reading with every visit</li>
        <li>Sedation always available, never forced</li>
        <li>Fog machine levels adjustable upon request</li>
        <li>Playlist vibe input taken seriously</li>
        <li>Free sticker, no exceptions, no substitutions</li>
        <li>Dr. Molarstone will make sustained eye contact</li>
        <li>Validated parking (for teeth only, regrettably)</li>
      </ul>
    </div>

    <!-- ═══ THE FORM ═══ -->
    <div class="form-card">
      <h2 class="form-card-title" id="form-heading">The Appointment Request Form™</h2>
      <p class="form-card-sub">Please complete all fields. Your mouth's future depends on it. No pressure.</p>

      <form id="destinyForm" aria-labelledby="form-heading" novalidate>

        <span class="form-section-title" aria-hidden="true">01 — About You (The Human)</span>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="fname">First Name <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
            <input class="form-input" id="fname" name="fname" type="text" placeholder="What your mother calls you" required autocomplete="given-name">
          </div>
          <div class="form-group">
            <label class="form-label" for="lname">Last Name <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
            <input class="form-input" id="lname" name="lname" type="text" placeholder="The rest of it" required autocomplete="family-name">
          </div>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="email">Email Address <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
            <input class="form-input" id="email" name="email" type="email" placeholder="For appointment confirmations + tooth updates" required autocomplete="email">
          </div>
          <div class="form-group">
            <label class="form-label" for="phone">Phone Number</label>
            <input class="form-input" id="phone" name="phone" type="tel" placeholder="For emergencies and wellness checks" autocomplete="tel">
          </div>
        </div>

        <div class="form-group">
          <label class="form-label" for="dob">Date of Birth</label>
          <input class="form-input" id="dob" name="dob" type="date" autocomplete="bday">
        </div>

        <span class="form-section-title" aria-hidden="true">02 — About Your Teeth (The Stars of the Show)</span>

        <div class="form-group">
          <label class="form-label" for="tooth-concern">Primary Tooth of Concern <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
          <select class="form-select" id="tooth-concern" name="tooth-concern" required>
            <option value="" disabled selected>— Select the tooth in question —</option>
            <optgroup label="Front of Mouth (The Socializers)">
              <option>Upper Central Incisor (Very Main Character Energy)</option>
              <option>Lower Central Incisor (Quietly Doing Its Best)</option>
              <option>Upper Lateral Incisor (Always the Bridesmaid)</option>
              <option>Lower Lateral Incisor (Reliable, Underrated)</option>
            </optgroup>
            <optgroup label="Side Teeth (The Versatile Ones)">
              <option>Upper Canine (Pointy, Passionate, Misunderstood)</option>
              <option>Lower Canine (The Quiet Intensity Type)</option>
              <option>Upper Premolar #1 (Competent Middle Management)</option>
              <option>Upper Premolar #2 (Also Fine)</option>
            </optgroup>
            <optgroup label="Molars (The Workhorses)">
              <option>Upper First Molar (Overworked, Underappreciated)</option>
              <option>Lower First Molar (Same, But Different)</option>
              <option>Second Molar (The Introverted One)</option>
              <option>Wisdom Tooth (Just Here Causing Problems)</option>
            </optgroup>
            <optgroup label="Other Situations">
              <option>Multiple Teeth (It's a Group Issue)</option>
              <option>All of Them (Let's Start Fresh)</option>
              <option>None, I'm Just Curious About the Experience</option>
              <option>I Don't Know — They All Look the Same to Me</option>
            </optgroup>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="tooth-feeling">Describe Your Tooth's Current Emotional State <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
          <textarea class="form-textarea" id="tooth-feeling" name="tooth-feeling" placeholder="e.g. 'Sensitive and reactive, especially when criticized.' Or 'Fine on the surface but something feels off deep down.' Or simply: 'In pain. Help.'" required></textarea>
        </div>

        <div class="form-group">
          <label class="form-label" for="last-visit">When Did You Last Visit a Dentist?</label>
          <select class="form-select" id="last-visit" name="last-visit">
            <option value="" disabled selected>— Select one —</option>
            <option>Within the last 6 months (Gold Star Patient)</option>
            <option>6 months to 1 year ago (Acceptable)</option>
            <option>1–2 years ago (We Don't Judge)</option>
            <option>2–5 years ago (We Really Don't Judge)</option>
            <option>5+ years ago (We Absolutely Do Not Judge You)</option>
            <option>Not since childhood (Welcome Home)</option>
            <option>I prefer not to say (Noted, Understood, Still Welcome)</option>
          </select>
        </div>

        <span class="form-section-title" aria-hidden="true">03 — Your Appointment Preferences</span>

        <div class="form-group">
          <label class="form-label" for="service">Desired Service <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></label>
          <select class="form-select" id="service" name="service" required>
            <option value="" disabled selected>— What does your mouth need? —</option>
            <option>The Illumination Cleaning (Standard + Energy Clearing)</option>
            <option>Diamond Whitening Ritual (8 Shades or We Try Again)</option>
            <option>Deep Cavity Excavation (We Go In)</option>
            <option>The Crown Coronation (Regal Treatment)</option>
            <option>Emergency Tooth Liberation (ASAP Please)</option>
            <option>Orthodontic Alignment Journey (Long Road)</option>
            <option>Full Mouth Assessment (Let Dr. Molarstone Decide)</option>
            <option>The Transcendent Package (All of It)</option>
            <option>Just the Tooth Reading, Honestly</option>
          </select>
        </div>

        <div class="form-row">
          <div class="form-group">
            <label class="form-label" for="pref-date">Preferred Date</label>
            <input class="form-input" id="pref-date" name="pref-date" type="date">
          </div>
          <div class="form-group">
            <label class="form-label" for="pref-time">Preferred Time Slot</label>
            <select class="form-select" id="pref-time" name="pref-time">
              <option value="" disabled selected>— Select a window —</option>
              <option>Morning: 9am–11am (Dr. M is alert but not cheerful yet)</option>
              <option>Midday: 11am–1pm (Peak Performance Hours)</option>
              <option>Afternoon: 1pm–4pm (Post-lunch Enlightenment Window)</option>
              <option>Late: 4pm–6pm (Golden Hour Dentistry)</option>
              <option>Emergency After-Hours (Surcharge applies, worth it)</option>
              <option>Whenever, I Trust the Process</option>
            </select>
          </div>
        </div>

        <div class="form-group">
          <fieldset class="vibe-fieldset">
            <legend class="form-label">Preferred Appointment Vibe <span class="required-star" aria-hidden="true">*</span><span class="sr-only">(required)</span></legend>
            <div class="radio-group" role="group">
              <div class="radio-pill">
                <input type="radio" name="vibe" id="v1" value="chill" required>
                <label for="v1"><span aria-hidden="true">🕯️</span> Calm &amp; Meditative</label>
              </div>
              <div class="radio-pill">
                <input type="radio" name="vibe" id="v2" value="hype">
                <label for="v2"><span aria-hidden="true">⚡</span> High Energy Hype</label>
              </div>
              <div class="radio-pill">
                <input type="radio" name="vibe" id="v3" value="academia">
                <label for="v3"><span aria-hidden="true">📚</span> Dark Academia</label>
              </div>
              <div class="radio-pill">
                <input type="radio" name="vibe" id="v4" value="rave">
                <label for="v4"><span aria-hidden="true">🪩</span> Full Dental Rave</label>
              </div>
              <div class="radio-pill">
                <input type="radio" name="vibe" id="v5" value="whatever">
                <label for="v5"><span aria-hidden="true">🤷</span> Whatever She Decides</label>
              </div>
            </div>
          </fieldset>
        </div>

        <span class="form-section-title" aria-hidden="true">04 — Insurance &amp; Practicalities</span>

        <div class="form-group">
          <label class="form-label" for="insurance">Insurance Provider</label>
          <select class="form-select" id="insurance" name="insurance">
            <option value="" disabled selected>— Select your coverage situation —</option>
            <option>Delta Dental (Classic)</option>
            <option>Cigna Dental (Also Classic)</option>
            <option>MetLife (The Dependable One)</option>
            <option>Aetna (Sure)</option>
            <option>Guardian (Watching Over Your Teeth)</option>
            <option>No Insurance — Paying Out of Pocket (Brave)</option>
            <option>My Teeth Are Covered By Love and Intention</option>
            <option>Spiritual Insurance (We Accept This)</option>
            <option>I Will Figure It Out at the Front Desk</option>
            <option>My Employer Provides It But I've Never Read the Card</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="sedation">Sedation Preference</label>
          <select class="form-select" id="sedation" name="sedation">
            <option value="" disabled selected>— Optional but valid to discuss —</option>
            <option>No sedation needed — I face my fears</option>
            <option>Nitrous oxide please (light and floaty)</option>
            <option>Oral sedation (a little something to take the edge off)</option>
            <option>Surprise me (within reason)</option>
            <option>I prefer to discuss this with Dr. Molarstone directly</option>
          </select>
        </div>

        <div class="form-group">
          <label class="form-label" for="playlist">Playlist Song Request (Optional but Encouraged)</label>
          <input class="form-input" id="playlist" name="playlist" type="text" placeholder="e.g. 'Something to get through a crown placement. Anything by Fleetwood Mac.' OR 'Full send, give me the rave playlist.'">
        </div>

        <div class="form-group">
          <label class="form-label" for="notes">Anything Else Dr. Molarstone Should Know?</label>
          <textarea class="form-textarea" id="notes" name="notes" placeholder="Special concerns, fears, requests, personal affirmations you'd like read to you mid-procedure, dietary restrictions (for the complimentary fluoride flavor selection), etc."></textarea>
        </div>

        <div class="submit-zone">
          <button type="submit" class="submit-btn" id="submit-btn"><span aria-hidden="true">✦</span> MANIFEST MY APPOINTMENT <span aria-hidden="true">✦</span></button>
          <p class="submit-disclaimer">By submitting this form you confirm that your teeth exist, that you acknowledge they deserve care, and that you consent to receiving one (1) tooth-related email per week (unsubscribe available, but why would you?). This form does not constitute a binding dental contract. Results may vary. Side effects include improved oral health and a sudden interest in molars.</p>
        </div>

      </form>
    </div>
  </div>

  <div class="divider" aria-hidden="true"></div>

  <!-- ═══ INFO STRIP ═══ -->
  <section class="info-strip" aria-labelledby="info-heading">
    <h2 id="info-heading" class="sr-only">Visit Information</h2>
    <div class="info-strip-inner">
      <div class="info-block">
        <span class="info-icon" aria-hidden="true">📍</span>
        <span class="info-label">Location</span>
        <div class="info-value">123 Enamel Ave, Suite <span aria-hidden="true">🦷</span><br>Los Angeles, CA 90210<br><strong>(Formerly a laser tag arena)</strong></div>
      </div>
      <div class="info-block">
        <span class="info-icon" aria-hidden="true">⏰</span>
        <span class="info-label">Hours</span>
        <div class="info-value">Mon–Fri: 9am – 6pm<br>Sat: 10am – 4pm<br><strong>Emergencies: Always*</strong></div>
      </div>
      <div class="info-block">
        <span class="info-icon" aria-hidden="true">📞</span>
        <span class="info-label">Contact</span>
        <div class="info-value"><a href="tel:5558664863">(555) TOOTH-ME</a><br><a href="mailto:hello@chomperz.dental">hello@chomperz.dental</a><br><strong>Text preferred before 10am</strong></div>
      </div>
      <div class="info-block">
        <span class="info-icon" aria-hidden="true">🚗</span>
        <span class="info-label">Parking</span>
        <div class="info-value">Street parking available<br>Validated for Transcendent members<br><strong>Teeth do not need parking</strong></div>
      </div>
    </div>
  </section>

  </main>

  <!-- ═══ SUCCESS MODAL ═══ -->
  <div
    class="modal-overlay"
    id="successModal"
    role="dialog"
    aria-modal="true"
    aria-labelledby="modal-title"
    aria-describedby="modal-body"
    hidden
  >
    <div class="modal-box">
      <span class="modal-tooth" aria-hidden="true">🦷</span>
      <h2 class="modal-title" id="modal-title">DESTINY MANIFESTED</h2>
      <p class="modal-body" id="modal-body">
        Your appointment request has been received by the universe — and also by Dr. Molarstone's inbox.<br><br>
        Expect a confirmation within <strong>1–2 business days</strong> (or whenever she finishes her morning crystal alignment routine). In the meantime, please drink water, floss <em>once</em> (we're not going to tell you twice), and know that your teeth's future is bright.<br><br>
        <strong>Your complimentary tooth reading has already begun.</strong><br>
        <em>Preliminary findings: Your upper right canine has main character energy. More at your appointment.</em>
      </p>
      <button class="modal-btn" id="modal-close">RETURN TO REALITY</button>
    </div>
  </div>

  <Footer />
</BaseLayout>

<script is:inline>
(function () {
  // ── Fake countdown
  var secs = 9 * 60 + 47;
  var cd = document.getElementById('countdown');
  if (cd) {
    setInterval(function () {
      if (secs <= 0) { secs = 14 * 60 + 59; return; }
      secs--;
      var m = String(Math.floor(secs / 60)).padStart(2, '0');
      var s = String(secs % 60).padStart(2, '0');
      cd.textContent = m + ':' + s;
    }, 1000);
  }

  // ── Modal helpers
  var modal = document.getElementById('successModal');
  var closeBtn = document.getElementById('modal-close');
  var submitBtn = document.getElementById('submit-btn');
  var previousFocus = null;

  function openModal() {
    previousFocus = document.activeElement;
    modal.removeAttribute('hidden');
    modal.style.display = 'flex';
    document.body.style.overflow = 'hidden';
    // Move focus into modal
    closeBtn.focus();
    // Trap focus inside modal
    modal.addEventListener('keydown', trapFocus);
  }

  function closeModal() {
    modal.setAttribute('hidden', '');
    modal.style.display = '';
    document.body.style.overflow = '';
    modal.removeEventListener('keydown', trapFocus);
    document.getElementById('destinyForm').reset();
    // Return focus to submit button
    if (previousFocus) previousFocus.focus();
  }

  function trapFocus(e) {
    if (e.key !== 'Tab') return;
    var focusable = modal.querySelectorAll('button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])');
    var first = focusable[0];
    var last = focusable[focusable.length - 1];
    if (e.shiftKey) {
      if (document.activeElement === first) { e.preventDefault(); last.focus(); }
    } else {
      if (document.activeElement === last) { e.preventDefault(); first.focus(); }
    }
  }

  // Close on Escape
  document.addEventListener('keydown', function (e) {
    if (e.key === 'Escape' && !modal.hidden) closeModal();
  });

  // Close on overlay click
  modal.addEventListener('click', function (e) {
    if (e.target === modal) closeModal();
  });

  closeBtn.addEventListener('click', closeModal);

  // ── Form submit
  var form = document.getElementById('destinyForm');
  if (form) {
    form.addEventListener('submit', function (e) {
      e.preventDefault();
      openModal();
    });
  }
})();
</script>

<style>
/* ── SCREEN READER ONLY ── */
.sr-only {
  position: absolute;
  width: 1px; height: 1px;
  padding: 0; margin: -1px;
  overflow: hidden;
  clip: rect(0,0,0,0);
  white-space: nowrap;
  border-width: 0;
}

/* ── PAGE HERO ── */
.page-hero {
  min-height: 52vh;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  text-align: center;
  padding: 80px 24px 60px;
  position: relative;
  overflow: hidden;
  background: radial-gradient(ellipse at 50% 70%, #1a0044 0%, #0d0d1a 65%);
}

.page-hero-glow {
  position: absolute;
  width: 500px; height: 500px;
  border-radius: 50%;
  background: radial-gradient(circle, rgba(204,255,0,.12) 0%, transparent 70%);
  animation: glowPulse 4s ease-in-out infinite alternate;
  pointer-events: none;
}

@keyframes glowPulse {
  from { transform: scale(1); opacity: .5; }
  to   { transform: scale(1.5); opacity: 1; }
}

.page-hero-eyebrow {
  position: relative; z-index: 2;
  background: #ccff00;
  color: #000;
  font-size: .65rem;
  font-weight: 900;
  letter-spacing: 4px;
  text-transform: uppercase;
  padding: 6px 18px;
  border-radius: 20px;
  margin-bottom: 24px;
  animation: eyebrowBounce .6s ease infinite alternate;
}

.page-hero h1 {
  position: relative; z-index: 2;
  font-size: clamp(3rem, 9vw, 7rem);
  font-weight: 900;
  line-height: .9;
  text-transform: uppercase;
  margin-bottom: 16px;
}

.h1-solid {
  display: block;
  background: linear-gradient(130deg, #fff 0%, #ccff00 55%, #00b4d8 100%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.h1-outline {
  display: block;
  -webkit-text-stroke: 3px #c8005a;
  color: transparent;
  filter: drop-shadow(0 0 18px #c8005a);
}

.page-hero-sub {
  position: relative; z-index: 2;
  font-size: 1.1rem;
  font-family: Georgia, serif;
  font-style: italic;
  color: rgba(255,255,255,.72);
  max-width: 540px;
  line-height: 1.75;
}

.page-hero-sub strong { color: #ccff00; font-style: normal; }

/* ── URGENCY BAR ── */
.urgency-bar {
  background: linear-gradient(90deg, #1a0030, #7b2d8b, #1a0030);
  border-top: 1px solid rgba(204,255,0,.2);
  border-bottom: 1px solid rgba(204,255,0,.2);
  padding: 16px 40px;
  text-align: center;
  font-size: .8rem;
  letter-spacing: 2px;
  text-transform: uppercase;
  color: rgba(255,255,255,.7);
  position: relative;
  z-index: 1;
}

.urgency-bar strong { color: #ccff00; }

#countdown {
  color: #c8005a;
  font-weight: 900;
  font-size: 1.1rem;
}

/* ── FORM OUTER ── */
.form-outer {
  padding: 72px 48px;
  max-width: 900px;
  margin: 0 auto;
}

.form-intro {
  margin-bottom: 48px;
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 40px;
  align-items: start;
}

.form-intro-text p {
  font-size: .9rem;
  font-family: Georgia, serif;
  color: rgba(255,255,255,.68);
  line-height: 1.8;
  margin-bottom: 14px;
}

.form-intro-text strong { color: #fff; }
.form-intro-text em { color: #ffd700; }

.trust-list { list-style: none; }
.trust-list li {
  padding: 10px 0;
  border-bottom: 1px solid rgba(255,255,255,.06);
  font-size: .82rem;
  color: rgba(255,255,255,.6);
  font-family: Georgia, serif;
}
.trust-list li::before { content: '🦷 '; }

/* ── FORM CARD ── */
.form-card {
  background: rgba(255,255,255,.03);
  border: 1px solid rgba(200,0,90,.2);
  border-radius: 14px;
  padding: 48px;
  box-shadow: 0 0 60px rgba(200,0,90,.06);
}

.form-card-title {
  font-size: 1.6rem;
  font-weight: 900;
  text-transform: uppercase;
  margin-bottom: 8px;
  background: linear-gradient(90deg, #c8005a, #00b4d8);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

.form-card-sub {
  font-size: .8rem;
  color: rgba(255,255,255,.4);
  font-family: Georgia, serif;
  margin-bottom: 36px;
  font-style: italic;
}

/* ── FORM ELEMENTS ── */
.form-row {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 20px;
}

.form-group { margin-bottom: 22px; }

.form-label {
  display: block;
  font-size: .62rem;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(255,255,255,.55);
  margin-bottom: 8px;
}

.required-star { color: #c8005a; }

.form-input,
.form-select,
.form-textarea {
  width: 100%;
  background: rgba(255,255,255,.05);
  border: 1px solid rgba(255,255,255,.1);
  border-radius: 6px;
  padding: 13px 16px;
  color: #fff;
  font-size: .95rem;
  font-family: 'Arial', sans-serif;
  transition: border-color .25s, box-shadow .25s, background .25s;
  outline: none;
  appearance: none;
}

.form-input::placeholder,
.form-textarea::placeholder {
